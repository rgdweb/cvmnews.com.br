  marginTop = (marginTop / 2) - ($(".div_info_home").height() / 2);
  
  if(marginTop < 0){
    marginTop = 0;
  }

  if($(".icon_play_radio").css("display") == "inline"){
    $(".icon_play").show();
    $(".icon_pause").hide();
  }else{
    $(".icon_play").hide();
    $(".icon_pause").show();      
