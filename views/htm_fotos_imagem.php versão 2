<script>
document.addEventListener('DOMContentLoaded',()=>{
let f=[],i=-1;
const p=document.getElementById('popup'),img=document.getElementById('img'),c=document.getElementById('close'),pr=document.getElementById('prev'),n=document.getElementById('next'),ct=document.getElementById('counter');

function open(el){
const d=el.dataset.images;
if(!d)return;
try{f=JSON.parse(d);if(f.length){i=0;show()}}catch(e){console.error('Erro JSON:',e)}
}

function show(){
if(!f[i])return;
img.style.display='none';
const tmp=new Image();
tmp.onload=()=>{
img.src=tmp.src;
img.style.display='block';
ct.textContent=(i+1)+'/'+f.length;
p.classList.add('s');
document.body.style.overflow='hidden';
};
tmp.onerror=()=>console.error('Erro ao carregar:',f[i]);
tmp.src=f[i];
}

function hide(){
p.classList.remove('s');
document.body.style.overflow='';
setTimeout(()=>{f=[];i=-1;img.src=''},300);
}

document.addEventListener('click',e=>{
const t=e.target.closest('.ft');
if(t)open(t);
if(e.target===c||e.target===p)hide();
if(e.target===n&&f.length>1){i=(i+1)%f.length;show()}
if(e.target===pr&&f.length>1){i=(i-1+f.length)%f.length;show()}
const cb=e.target.closest('.cb');
if(cb){
const car=document.querySelector(`.fc[data-group="${cb.dataset.group}"]`);
car.scrollLeft+=cb.classList.contains('n')?270:-270;
}
});

document.addEventListener('keydown',e=>{
if(!p.classList.contains('s'))return;
if(e.key==='Escape')hide();
if(e.key==='ArrowRight'&&f.length>1){i=(i+1)%f.length;show()}
if(e.key==='ArrowLeft'&&f.length>1){i=(i-1+f.length)%f.length;show()}
});

document.querySelectorAll('.fc').forEach(car=>{
let sx,sl,down=false;
car.addEventListener('touchstart',e=>{
down=true;
sx=e.touches[0].pageX-car.offsetLeft;
sl=car.scrollLeft;
car.style.scrollBehavior='auto';
});
car.addEventListener('touchmove',e=>{
if(!down)return;
e.preventDefault();
const x=e.touches[0].pageX-car.offsetLeft;
car.scrollLeft=sl-(x-sx)*1.5;
});
car.addEventListener('touchend',()=>{
down=false;
car.style.scrollBehavior='smooth';
});
car.addEventListener('mousedown',e=>{
down=true;
sx=e.pageX-car.offsetLeft;
sl=car.scrollLeft;
car.style.scrollBehavior='auto';
});
car.addEventListener('mousemove',e=>{
if(!down)return;
e.preventDefault();
const x=e.pageX-car.offsetLeft;
car.scrollLeft=sl-(x-sx)*1.5;
});
car.addEventListener('mouseup',()=>{
down=false;
car.style.scrollBehavior='smooth';
});
car.addEventListener('mouseleave',()=>{
down=false;
car.style.scrollBehavior='smooth';
});
});
});
</script>
